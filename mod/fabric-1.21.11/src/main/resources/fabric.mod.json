{
  "schemaVersion": 1,
  "id": "debugbridge",
  "version": "${version}",
  "name": "DebugBridge",
  "description": "Lua-Java bridge for Minecraft: a WebSocket REPL into the running client, with auto-downloaded Mojang mappings so you can script the game using official class names.",
  "authors": [
    "Weikeng Chen"
  ],
  "contact": {
    "homepage": "https://github.com/weikengchen/debugbridge",
    "sources": "https://github.com/weikengchen/debugbridge",
    "issues": "https://github.com/weikengchen/debugbridge/issues"
  },
  "license": "MIT",
  "icon": "assets/debugbridge/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.debugbridge.fabric12111.DebugBridgeMod"
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "1.21.11"
  },
  "mixins": [
    "debugbridge.mixins.json"
  ]
}
