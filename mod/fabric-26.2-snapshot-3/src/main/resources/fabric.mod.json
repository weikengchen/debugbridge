{
    "schemaVersion": 1,
    "id": "debugbridge",
    "version": "${version}",
    "name": "DebugBridge 26.2 Snapshot Bridge",
    "description": "DebugBridge development build for Minecraft 26.2-snapshot-3 with boot path parity and stub providers.",
    "authors": ["Weikeng Chen"],
    "contact": {
        "homepage": "https://github.com/weikengchen/debugbridge",
        "sources": "https://github.com/weikengchen/debugbridge",
        "issues": "https://github.com/weikengchen/debugbridge/issues"
    },
    "license": "MIT",
    "icon": "assets/debugbridge/icon.png",
    "environment": "client",
    "mixins": [
        "debugbridge.mixins.json"
    ],
    "entrypoints": {
        "client": [
            "com.debugbridge.fabric262.DebugBridgeMod"
        ]
    },
    "depends": {
        "fabricloader": ">=0.19.2",
        "minecraft": "26.2-snapshot-3"
    }
}
